APP_NAME=Paris Agent API
SERVICE_NAME=paris-agent-api
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
MOCK_RUN_STEP_DELAY_SECONDS=0.2
SSE_HEARTBEAT_SECONDS=15

DATABASE_URL=postgresql+asyncpg://paris_agent:change_me_postgres@127.0.0.1:5432/paris_agent
REDIS_URL=redis://:change_me_redis@127.0.0.1:6379/0
RABBITMQ_URL=amqp://paris_agent:change_me_rabbitmq@127.0.0.1:5672/

MEMORY_TEXT_WEIGHT=0.40
MEMORY_IMPORTANCE_WEIGHT=0.20
MEMORY_CONFIDENCE_WEIGHT=0.10
MEMORY_RECENCY_WEIGHT=0.10
MEMORY_ACCESS_WEIGHT=0.05
MEMORY_PROJECT_WEIGHT=0.15
